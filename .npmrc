# Expo SDK 54 pins React 19.1.0, but transitive deps (expo-router →
# @expo/metro-runtime → react-dom 19.2.5) peer-require react ^19.2.5.
# This is a known Expo 54 / React 19 ecosystem mismatch — npm 7+'s strict
# peer-dep checker refuses to install. Legacy mode (npm 6 behaviour)
# falls back to warning instead of failing, which is what Expo itself
# recommends for SDK 54 projects.
#
# Tradeoff: peer conflicts still show as warnings. If Expo bumps React
# to 19.2.x in SDK 55 this flag can be removed.
legacy-peer-deps=true
