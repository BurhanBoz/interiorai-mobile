# Development environment (default)
EXPO_PUBLIC_API_URL=http://192.168.0.28:8080
EXPO_PUBLIC_ENV=development
EXPO_PUBLIC_APP_NAME=The Architectural Lens (Dev)
EXPO_PUBLIC_ENABLE_LOGGING=true

# ── Google Sign-In (Expo AuthSession) ────────────────────────────────
# Create these in Google Cloud Console → APIs & Services → Credentials:
#   1) iOS client (Bundle ID: com.thearchitecturallens.mobile) → EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID
#   2) Web client (no redirect URI required)                    → EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID
# Then add the same values to the backend .env (GOOGLE_IOS_CLIENT_ID / GOOGLE_WEB_CLIENT_ID).
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=temporary-placeholder-for-ios-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=21314937170-lu8vdvfs8n7pcq6nolf454aaqsnhde05.apps.googleusercontent.com
