# ═════════════════════════════════════════════════════════════════════
#  Roomframe AI — Mobile Environment Variables
#
#  Local dev:  Copy this to `.env`, fill in values, run `npx expo start`.
#  EAS build:  Set in eas.json profile env or App Store Connect.
#
#  Note: Anything prefixed with EXPO_PUBLIC_ is BAKED INTO THE BUNDLE
#  and visible to anyone who decompiles the IPA. Don't put true secrets
#  here. (Service-side secrets stay on the backend.)
# ═════════════════════════════════════════════════════════════════════

# ── App ──────────────────────────────────────────────────────────────
# Backend API endpoint.
# Dev (Simulator on same Mac): http://localhost:8080
# Dev (physical device on LAN): http://<your-mac-LAN-IP>:8080
# Prod: https://api.roomframeai.com
EXPO_PUBLIC_API_URL=http://localhost:8080

# Environment marker: development | staging | production
EXPO_PUBLIC_ENV=development

# Display name shown in About / Settings screens.
EXPO_PUBLIC_APP_NAME=Roomframe AI (Dev)

# Verbose console.log output for API calls. Off in prod for performance.
EXPO_PUBLIC_ENABLE_LOGGING=true

# ── Google Sign-In (Expo AuthSession) ────────────────────────────────
# Google Cloud Console → APIs & Services → Credentials → "Create OAuth client ID"
# Create two OAuth 2.0 Client IDs:
#   1) iOS         (Bundle ID: com.roomframeai.mobile) → EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID
#   2) Web         (no redirect URI required)          → EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID
# Both IDs are PUBLIC by design (Google's threat model treats them as identifiers,
# not secrets). The corresponding Web Client *secret* lives only on the backend.
# Mirror these values into the backend .env (GOOGLE_IOS_CLIENT_ID / GOOGLE_WEB_CLIENT_ID).
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
