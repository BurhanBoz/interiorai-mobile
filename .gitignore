# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store

# MCP config (contains API keys)
.vscode/mcp.json
*.pem

# Environment / Secrets — NEVER commit these.
# Pattern matches .env, .env.local, .env.production, .env.development, etc.
# Whitelist .env.example so the template stays in repo as documentation.
.env
*.env
!.env.example

# typescript
*.tsbuildinfo

# generated native folders
/ios
/android
